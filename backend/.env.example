# ─────────────────────────────────────────────────────────────
# GoLocal backend — environment variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# ─────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database (Supabase Postgres + PostGIS) ──────────────────
# Use the *transaction pooler* URL (port 6543), not the direct
# connection (5432). Direct connections don't work from Railway.
# Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgres://postgres:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Clerk (Auth) ────────────────────────────────────────────
# Dashboard → API keys. Test keys start sk_test_, live keys sk_live_.
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# ── Redis (Upstash) ─────────────────────────────────────────
# Upstash → Database → Details. URL has rediss:// scheme in prod.
REDIS_URL=redis://default:password@host:6379
REDIS_TOKEN=

# ── Cloudflare R2 (image storage) ───────────────────────────
# Cloudflare dashboard → R2 → Manage R2 API tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=golocal-media
R2_PUBLIC_BASE_URL=https://media.golocal.app

# ── Cloudflare Stream (video) ───────────────────────────────
# Cloudflare dashboard → Stream → API tokens.
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=

# ── Expo Push Notifications ─────────────────────────────────
# Optional. Required for higher rate limits.
# https://docs.expo.dev/push-notifications/sending-notifications/#additional-security
EXPO_ACCESS_TOKEN=

# ── Sentry (error tracking) ─────────────────────────────────
# Sentry → Project → Settings → Client Keys (DSN)
SENTRY_DSN=

# ── BullMQ / Notification worker ────────────────────────────
# When true, this process also runs the BullMQ worker in-process.
# In production, run the worker as a separate Railway service and set this to false.
RUN_WORKER_IN_PROCESS=true
