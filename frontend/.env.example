# ─────────────────────────────────────────────────────────────
# GoLocal frontend — environment variables template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Backend API base URL (http://localhost:3000 for local dev)
EXPO_PUBLIC_API_URL=

# Clerk publishable key — Clerk dashboard → API keys → Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
